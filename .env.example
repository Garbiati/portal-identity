# Copie para .env (gitignored) e ajuste. Em PROD, nada disso fica em arquivo: GCP Secret Manager.

# Admin do console do Keycloak (bootstrap, ambiente local).
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=Admin@dev12345

# Secret do service account `doctor-hub-admin` (a doctor-hub-api usa p/ gerir usuários via Admin API).
# Mesmo valor deve estar na config da API. Em prod: Secret Manager.
ADMIN_CLIENT_SECRET=troque-em-dev

# --- SMTP (envio real de e-mail: código OTP + "Esqueceu a senha?") ---
# Vazio = e-mail não envia (a opção aparece, mas mostra "não foi possível enviar").
# DEV sem conta: suba um Mailpit (docker run -d --name mailpit -p 1025:1025 -p 8025:8025 axllent/mailpit)
#   e use SMTP_HOST=localhost SMTP_PORT=1025 SMTP_AUTH=false SMTP_STARTTLS=false  (UI em http://localhost:8025)
# DEV/prod com SMTP real (SendGrid/Workspace/SES): preencha host/porta/usuário/senha + AUTH=true.
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=nao-responda@seu-dominio
SMTP_FROM_DISPLAY=Portal Telemedicina
SMTP_AUTH=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_STARTTLS=true          # 587=STARTTLS; para 465 use SMTP_SSL=true e STARTTLS=false
SMTP_SSL=false

# --- Twilio (envio real de SMS do código) ---
# Vazio = SMS não envia (opção aparece, mostra "não foi possível enviar").
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=                # número remetente em E.164, ex.: +15555555555

# --- DEV: logar o código (destino mascarado) p/ conferência. Em PROD deixe false. ---
OTP_DEV_LOG_CODE=true
